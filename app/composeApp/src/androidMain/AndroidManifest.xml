<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- In-app updater: sideload a newer signed APK (GitHub Releases). Must be
         dropped from any future Play Store flavor (Play prohibits this). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".LatticeApplication"
        android:label="lattice"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:allowBackup="false"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Lattice">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="lattice">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- urb:// deep links. Lets other apps (e.g. Talon) hand
                 off an Urbit address for Lattice to browse. BROWSABLE
                 so a urb:// tapped anywhere on the device resolves
                 here; DEFAULT so an explicit ACTION_VIEW intent is
                 matched. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="urb" />
            </intent-filter>
            <!-- Share target: receive a shared web page / URL / text, or a
                 text file, and convert it to a gemtext file on the ship. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="text/*" />
            </intent-filter>
        </activity>

        <!-- Serves the downloaded APK to the system package installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.updates.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/updates_paths" />
        </provider>
    </application>

</manifest>
