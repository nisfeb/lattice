<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext (http) is permitted ONLY for loopback: local dev, an on-device
         ship, or the emulator's host (10.0.2.2). The +code and session cookie
         must never traverse a network in the clear. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    <!-- Everything else: https only (this is also the platform default on API 28+). -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
