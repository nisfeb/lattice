# Local MCP server config — contains a session cookie, never commit
.mcp.json

# KMP app build artifacts
app/local.properties
app/.gradle/
app/build/
app/composeApp/build/
app/.kotlin/

# Release-build artifacts (produced by scripts/ + the release workflow)
/build/
/dist/*.AppImage

# Signing material — NEVER commit a keystore or its passwords
*.keystore
*.jks
keystore.properties

# JVM crash logs
hs_err_pid*.log
replay_pid*.log

# peru dependency vendoring
.peru/
dist-dev/

# Python bytecode cache
__pycache__/
*.pyc

# Claude Code session dir
.claude/
